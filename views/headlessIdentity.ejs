<%- include('partials/_head', {
  title: 'Headless Identity — Clintox',
  extraHead: '<script src="https://www.google.com/recaptcha/api.js?render=6Leh4aosAAAAAPBgLqFJ7dntmNYJvgefnufRpMiE"></script>'
}) %>

<h1 class="mb-3">Forgot Password</h1>
<p class="page-desc mb-4">Initiate a headless identity password reset via Salesforce.</p>

<div id="form-container">
  <div class="mb-3">
    <label for="username" class="form-label-upper">Username</label>
    <input type="email" id="username" class="form-control" placeholder="Enter your username" required>
  </div>
  <button id="reset-btn" class="btn btn-primary">Send Reset Email</button>
  <p id="message" class="mt-3"></p>
</div>

<div id="password-container" class="mt-4">
  <h2>Set New Password</h2>
  <p class="page-desc mb-4">Enter the OTP from your email along with your new password.</p>
  <div class="mb-3">
    <label class="form-label-upper">Confirm Username</label>
    <input type="text" id="reset_username" class="form-control mb-2" placeholder="Confirm username" required>
    <label class="form-label-upper mt-2">OTP</label>
    <input type="text" id="otp" class="form-control mb-2" placeholder="Enter OTP" required>
    <label class="form-label-upper mt-2">New Password</label>
    <input type="password" id="password" class="form-control" placeholder="Enter new password" required>
  </div>
  <button id="newpassword-btn" class="btn btn-primary">Update Password</button>
  <p id="newPasswordMessage" class="mt-3"></p>
</div>

<script nonce="<%= cspNonce %>">
  const SITE_KEY = '6Leh4aosAAAAAPBgLqFJ7dntmNYJvgefnufRpMiE';

  document.getElementById('reset-btn').addEventListener('click', async () => {
    const username = document.getElementById('username').value;
    const messageEl = document.getElementById('message');

    if (!username) {
      messageEl.style.color = 'var(--danger)';
      messageEl.innerText = 'Please enter a username.';
      return;
    }

    grecaptcha.ready(function() {
      grecaptcha.execute(SITE_KEY, { action: 'forgot_password' }).then(async (token) => {
        try {
          const response = await fetch('/forgot-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, captchaToken: token })
          });
          const result = await response.json();

          if (response.ok) {
            messageEl.style.color = 'var(--success)';
            messageEl.innerText = 'Check your inbox for a reset link!';
            document.getElementById('password-container').style.display = 'block';
            document.getElementById('form-container').style.display = 'none';
          } else {
            messageEl.style.color = 'var(--danger)';
            messageEl.innerText = 'Error: ' + (result.message || 'Request failed');
          }
        } catch (err) {
          messageEl.style.color = 'var(--danger)';
          messageEl.innerText = 'Connection error.';
        }
      });
    });
  });

  document.getElementById('newpassword-btn').addEventListener('click', async () => {
    const reset_username = document.getElementById('reset_username').value;
    const otp = document.getElementById('otp').value;
    const password = document.getElementById('password').value;
    const messageEl = document.getElementById('newPasswordMessage');

    if (!reset_username || !otp || !password) {
      messageEl.style.color = 'var(--danger)';
      messageEl.innerText = 'All fields are required.';
      return;
    }

    grecaptcha.ready(function() {
      grecaptcha.execute(SITE_KEY, { action: 'forgot_password' }).then(async (token) => {
        try {
          const response = await fetch('/new-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username: reset_username, otp, newpassword: password, recaptcha: token })
          });
          const result = await response.json();

          if (response.ok) {
            messageEl.style.color = 'var(--success)';
            messageEl.innerText = 'Success! New password set.';
          } else {
            messageEl.style.color = 'var(--danger)';
            messageEl.innerText = 'Error: ' + (result.message || 'Request failed');
          }
        } catch (err) {
          messageEl.style.color = 'var(--danger)';
          messageEl.innerText = 'Connection error.';
        }
      });
    });
  });
</script>

<%- include('partials/_foot') %>
