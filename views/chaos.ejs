<!doctype html>
<html lang="en" class="h-100" data-bs-theme="auto">
<head>
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MHKF1Q3QBE"></script>
  <script nonce="<%= cspNonce %>">
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-MHKF1Q3QBE');
  </script>

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Chaos Mode — API Test App</title>

  <link rel="icon" href="/favicon.ico" sizes="16x16 32x32" type="image/x-icon">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
  <meta name="theme-color" content="#712cf9">

  <style>
    body { background-color: #1a1a2e; color: #e0e0e0; }
    .badge-pass { background-color: #198754; }
    .badge-fail { background-color: #dc3545; }
    pre { white-space: pre-wrap; word-break: break-word; font-size: 0.8rem; background: #0d0d0d; padding: 0.5rem; border-radius: 4px; max-height: 120px; overflow-y: auto; }
    .probe-card { background: #16213e; border: 1px solid #0f3460; }
    .spinner-border { width: 1.2rem; height: 1.2rem; }
  </style>
</head>

<body class="d-flex flex-column min-vh-100 text-bg-dark p-3">
  <header class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
      <h3 class="mb-0">Clintox</h3>
      <nav>
        <a class="nav-link d-inline fw-bold" href="/">Home</a>
      </nav>
    </div>
  </header>

  <main class="container-fluid flex-grow-1">
    <h1 class="mb-1">Data Integrity Chaos Mode</h1>
    <p class="text-secondary mb-4">Fires malformed payloads at the Salesforce Account sObject and catalogs every error shape returned. Requires an active OAuth session.</p>

    <% if (!hasToken) { %>
      <div class="alert alert-warning" role="alert">
        No active session detected. <a href="/auth" class="alert-link">Complete an OAuth flow first</a>, then return here.
      </div>
    <% } %>

    <div class="mb-4">
      <button id="runBtn" class="btn btn-danger" <%= !hasToken ? 'disabled' : '' %>>
        Run Chaos Probes
      </button>
      <span id="spinner" class="ms-2 d-none">
        <span class="spinner-border" role="status"></span>
        <span class="ms-1">Running 6 probes…</span>
      </span>
    </div>

    <div id="error-banner" class="alert alert-danger d-none" role="alert"></div>

    <div id="results" class="row g-3"></div>
  </main>

  <footer class="mt-4 text-center text-secondary small">
    All probes target your authenticated Salesforce org. No data is persisted on success.
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4"
    crossorigin="anonymous"></script>

  <script nonce="<%= cspNonce %>">
    const btn = document.getElementById('runBtn');
    const spinner = document.getElementById('spinner');
    const resultsEl = document.getElementById('results');
    const errorBanner = document.getElementById('error-banner');

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      spinner.classList.remove('d-none');
      resultsEl.innerHTML = '';
      errorBanner.classList.add('d-none');

      try {
        const res = await fetch('/chaos/run', { method: 'POST' });
        const json = await res.json();

        if (!res.ok) {
          errorBanner.textContent = json.error || 'Request failed.';
          errorBanner.classList.remove('d-none');
          return;
        }

        json.results.forEach(r => {
          const col = document.createElement('div');
          col.className = 'col-12 col-md-6 col-xl-4';

          const passed = r.passed;
          const badgeClass = passed ? 'badge-pass' : 'badge-fail';
          const badgeLabel = passed ? 'PASS (unexpected success)' : 'FAIL (expected rejection)';

          col.innerHTML = `
            <div class="card probe-card h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h6 class="card-title mb-0">${escHtml(r.label)}</h6>
                  <span class="badge ${badgeClass} ms-2 flex-shrink-0">${badgeLabel}</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                  <span class="badge bg-secondary">HTTP ${escHtml(String(r.status))}</span>
                  <span class="badge bg-dark border">${escHtml(String(r.ms))} ms</span>
                </div>
                <pre>${escHtml(JSON.stringify(r.body, null, 2))}</pre>
              </div>
            </div>`;
          resultsEl.appendChild(col);
        });
      } catch (err) {
        errorBanner.textContent = 'Network error: ' + err.message;
        errorBanner.classList.remove('d-none');
      } finally {
        btn.disabled = false;
        spinner.classList.add('d-none');
      }
    });

    function escHtml(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  </script>
</body>
</html>
