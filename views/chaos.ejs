<%- include('partials/_head', { title: 'Chaos Mode — Clintox' }) %>

<h1 class="mb-3">Data Integrity Chaos Mode</h1>
<p class="page-desc mb-4">Fires malformed payloads at the Salesforce Account sObject and catalogs every error shape returned. Requires an active OAuth session.</p>

<% if (!hasToken) { %>
  <div class="alert alert-warning mb-4" role="alert">
    No active session detected. <a href="/auth" class="alert-link">Complete an OAuth flow first</a>, then return here.
  </div>
<% } %>

<div class="mb-4 d-flex align-items-center gap-3">
  <button id="runBtn" class="btn btn-primary" <%= !hasToken ? 'disabled' : '' %>>
    Run Chaos Probes
  </button>
  <span id="spinner" class="d-none d-flex align-items-center gap-2 text-secondary text-sm">
    <span class="spinner-border text-secondary" role="status"></span>
    Running 6 probes&hellip;
  </span>
</div>

<div id="error-banner" class="alert alert-danger d-none mb-3" role="alert"></div>

<div id="summary" class="d-none"></div>

<div id="results" class="row g-3"></div>

<script nonce="<%= cspNonce %>">
  const btn = document.getElementById('runBtn');
  const spinner = document.getElementById('spinner');
  const resultsEl = document.getElementById('results');
  const errorBanner = document.getElementById('error-banner');
  const summaryEl = document.getElementById('summary');

  btn.addEventListener('click', async () => {
    btn.disabled = true;
    spinner.classList.remove('d-none');
    resultsEl.innerHTML = '';
    errorBanner.classList.add('d-none');
    summaryEl.classList.add('d-none');

    try {
      const res = await fetch('/chaos/run', { method: 'POST' });
      const json = await res.json();

      if (!res.ok) {
        errorBanner.textContent = json.error || 'Request failed.';
        errorBanner.classList.remove('d-none');
        return;
      }

      const total = json.results.length;
      const passed = json.results.filter(r => r.passed).length;
      const failed = total - passed;

      summaryEl.innerHTML = `
        <span class="text-secondary">${total} probes run</span>
        <span class="text-secondary">&middot;</span>
        <span class="badge badge-pass">${passed} PASS</span>
        <span class="badge badge-fail">${failed} FAIL</span>`;
      summaryEl.classList.remove('d-none');

      json.results.forEach(r => {
        const col = document.createElement('div');
        col.className = 'col-12 col-lg-6';

        const badgeClass = r.passed ? 'badge-pass' : 'badge-fail';
        const badgeLabel = r.passed ? 'PASS (unexpected success)' : 'FAIL (expected rejection)';

        col.innerHTML = `
          <div class="card probe-card h-100">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h6 class="card-title mb-0">${escHtml(r.label)}</h6>
                <span class="badge ${badgeClass} ms-2 flex-shrink-0">${badgeLabel}</span>
              </div>
              <div class="d-flex gap-2 mb-2">
                <span class="badge bg-secondary">HTTP ${escHtml(String(r.status))}</span>
                <span class="badge badge-neutral">${escHtml(String(r.ms))} ms</span>
              </div>
              <pre>${escHtml(JSON.stringify(r.body, null, 2))}</pre>
            </div>
          </div>`;
        resultsEl.appendChild(col);
      });
    } catch (err) {
      errorBanner.textContent = 'Network error: ' + err.message;
      errorBanner.classList.remove('d-none');
    } finally {
      btn.disabled = false;
      spinner.classList.add('d-none');
    }
  });

  function escHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
</script>

<%- include('partials/_foot') %>
