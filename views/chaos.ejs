<!doctype html>
<html lang="en" class="h-100" data-bs-theme="auto">

<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-MHKF1Q3QBE"></script>
  <script nonce="<%= cspNonce %>">
    window.dataLayer = window.dataLayer || [];
    function gtag() { dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-MHKF1Q3QBE');
  </script>
  <script src="https://getbootstrap.com/docs/5.3/assets/js/color-modes.js"></script>

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Fire malformed payloads at Salesforce and catalog every error shape returned." />
  <meta name="keywords" content="Salesforce, chaos, API testing, data integrity" />
  <meta name="author" content="Clintox" />
  <link rel="canonical" href="https://clintox.xyz" />
  <meta name="robots" content="index, follow" />

  <title>Chaos Mode — API Test App</title>

  <link rel="canonical" href="">
  <link rel="icon" href="/favicon.ico" sizes="16x16 32x32" type="image/x-icon">

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
  <meta name="theme-color" content="#712cf9">

  <style>
    .badge-pass { background-color: #198754; }
    .badge-fail { background-color: #dc3545; }
    pre { white-space: pre-wrap; word-break: break-word; font-size: 0.8rem; background: #0d0d0d; padding: 0.5rem; border-radius: 4px; max-height: 120px; overflow-y: auto; }
    .probe-card { background: #16213e; border: 1px solid #0f3460; }
    .spinner-border { width: 1.2rem; height: 1.2rem; }
  </style>

  <!-- Custom styles for this template -->
  <link href="https://getbootstrap.com/docs/5.3/examples/cover/cover.css" rel="stylesheet">
</head>

<body class="d-flex h-100 text-bg-dark">
  <svg xmlns="http://www.w3.org/2000/svg" style="display: none;">
    <symbol id="check2" viewBox="0 0 16 16">
      <path
        d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6.5 10.293l6.646-6.647a.5.5 0 0 1 .708 0z" />
    </symbol>
    <symbol id="circle-half" viewBox="0 0 16 16">
      <path d="M8 15A7 7 0 1 0 8 1v14zm0 1A8 8 0 1 1 8 0a8 8 0 0 1 0 16z" />
    </symbol>
    <symbol id="moon-stars-fill" viewBox="0 0 16 16">
      <path
        d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z" />
      <path
        d="M10.794 3.148a.217.217 0 0 1 .412 0l.387 1.162c.173.518.579.924 1.097 1.097l1.162.387a.217.217 0 0 1 0 .412l-1.162.387a1.734 1.734 0 0 0-1.097 1.097l-.387 1.162a.217.217 0 0 1-.412 0l-.387-1.162A1.734 1.734 0 0 0 9.31 6.593l-1.162-.387a.217.217 0 0 1 0-.412l1.162-.387a1.734 1.734 0 0 0 1.097-1.097l.387-1.162zM13.863.099a.145.145 0 0 1 .274 0l.258.774c.115.346.386.617.732.732l.774.258a.145.145 0 0 1 0 .274l-.774.258a1.156 1.156 0 0 0-.732.732l-.258.774a.145.145 0 0 1-.274 0l-.258-.774a1.156 1.156 0 0 0-.732-.732l-.774-.258a.145.145 0 0 1 0-.274l.774-.258c.346-.115.617-.386.732-.732L13.863.1z" />
    </symbol>
    <symbol id="sun-fill" viewBox="0 0 16 16">
      <path
        d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z" />
    </symbol>
  </svg>

  <div class="cover-container d-flex w-100 h-100 p-3 mx-auto flex-column">
    <header class="mb-auto">
      <div>
        <h3 class="float-md-start mb-0">Clintox</h3>
        <nav class="nav nav-masthead justify-content-center float-md-end">
          <a class="nav-link fw-bold py-1 px-0 active" aria-current="page" href="/">Home</a>
        </nav>
      </div>
    </header>

    <main class="px-3">
      <h1 class="mb-1">Data Integrity Chaos Mode</h1>
      <p class="lead mb-4">Fires malformed payloads at the Salesforce Account sObject and catalogs every error shape returned. Requires an active OAuth session.</p>

      <% if (!hasToken) { %>
        <div class="alert alert-warning" role="alert">
          No active session detected. <a href="/auth" class="alert-link">Complete an OAuth flow first</a>, then return here.
        </div>
      <% } %>

      <div class="mb-4">
        <button id="runBtn" class="btn btn-danger" <%= !hasToken ? 'disabled' : '' %>>
          Run Chaos Probes
        </button>
        <span id="spinner" class="ms-2 d-none">
          <span class="spinner-border" role="status"></span>
          <span class="ms-1">Running 6 probes…</span>
        </span>
      </div>

      <div id="error-banner" class="alert alert-danger d-none" role="alert"></div>

      <div id="results" class="row g-3"></div>
    </main>

    <footer class="mt-auto text-white-50">
      All probes target your authenticated Salesforce org. No data is persisted on success.
    </footer>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-kenU1KFdBIe4zVF0s0G1M5b4hcpxyD9F7jL+jjXkk+Q2h455rYXK/7HAuoJl+0I4"
    crossorigin="anonymous"></script>

  <script nonce="<%= cspNonce %>">
    const btn = document.getElementById('runBtn');
    const spinner = document.getElementById('spinner');
    const resultsEl = document.getElementById('results');
    const errorBanner = document.getElementById('error-banner');

    btn.addEventListener('click', async () => {
      btn.disabled = true;
      spinner.classList.remove('d-none');
      resultsEl.innerHTML = '';
      errorBanner.classList.add('d-none');

      try {
        const res = await fetch('/chaos/run', { method: 'POST' });
        const json = await res.json();

        if (!res.ok) {
          errorBanner.textContent = json.error || 'Request failed.';
          errorBanner.classList.remove('d-none');
          return;
        }

        json.results.forEach(r => {
          const col = document.createElement('div');
          col.className = 'col-12 col-md-6 col-xl-4';

          const passed = r.passed;
          const badgeClass = passed ? 'badge-pass' : 'badge-fail';
          const badgeLabel = passed ? 'PASS (unexpected success)' : 'FAIL (expected rejection)';

          col.innerHTML = `
            <div class="card probe-card h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h6 class="card-title mb-0">${escHtml(r.label)}</h6>
                  <span class="badge ${badgeClass} ms-2 flex-shrink-0">${badgeLabel}</span>
                </div>
                <div class="d-flex gap-2 mb-2">
                  <span class="badge bg-secondary">HTTP ${escHtml(String(r.status))}</span>
                  <span class="badge bg-dark border">${escHtml(String(r.ms))} ms</span>
                </div>
                <pre>${escHtml(JSON.stringify(r.body, null, 2))}</pre>
              </div>
            </div>`;
          resultsEl.appendChild(col);
        });
      } catch (err) {
        errorBanner.textContent = 'Network error: ' + err.message;
        errorBanner.classList.remove('d-none');
      } finally {
        btn.disabled = false;
        spinner.classList.add('d-none');
      }
    });

    function escHtml(str) {
      return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
  </script>
</body>

</html>
