<%- include('partials/_head', { title: 'SOQL Query Runner — Clintox' }) %>

<h1 class="mb-3">SOQL Query Runner</h1>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger mb-3" role="alert"><%= error %></div>
<% } %>

<form method="POST" action="/soql" class="mb-4">
  <div class="mb-3">
    <textarea name="query" rows="4" class="form-control font-monospace" placeholder="SELECT Id, Name FROM Account LIMIT 10"><%= typeof query !== 'undefined' && query ? query : '' %></textarea>
  </div>
  <div class="d-flex align-items-center gap-3">
    <button type="submit" class="btn btn-primary">Run Query</button>
    <div class="form-check mb-0">
      <input class="form-check-input" type="checkbox" name="showRaw" id="showRaw" <%= (typeof showRaw !== 'undefined' && showRaw) ? 'checked' : '' %>>
      <label class="form-check-label" for="showRaw">Show raw JSON</label>
    </div>
  </div>
</form>

<% if (typeof results !== 'undefined' && results !== null) { %>
  <% if (results.length === 0) { %>
    <p class="text-secondary">Query returned no results.</p>
  <% } else { %>
    <p class="mb-3">Returned <strong><%= totalSize %></strong> record(s).</p>
    <%
      const cols = Object.keys(results[0]).filter(k => k !== 'attributes');
    %>
    <div class="table-responsive mb-4">
      <table class="table table-sm table-bordered">
        <thead>
          <tr>
            <% cols.forEach(col => { %><th><%= col %></th><% }); %>
          </tr>
        </thead>
        <tbody>
          <% results.forEach(record => { %>
            <tr>
              <% cols.forEach(col => { %>
                <td><%= (record[col] !== null && typeof record[col] === 'object') ? JSON.stringify(record[col]) : record[col] %></td>
              <% }); %>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>

  <% if (typeof showRaw !== 'undefined' && showRaw) { %>
    <pre class="bg-light p-3 border rounded"><%= rawJson %></pre>
  <% } %>
<% } %>

<a href="/" class="btn btn-outline-secondary mt-2">Back to Dashboard</a>

<%- include('partials/_foot') %>
