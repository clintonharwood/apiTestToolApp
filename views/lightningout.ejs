<%- include('partials/_head', {
  title: 'Lightning Out 2.0 — Clintox',
  extraHead: '<script type="text/javascript" async src="https://clintoxsupport.my.salesforce.com/lightning/lightning.out.latest/index.iife.prod.js"></script>'
}) %>

<h1>Lightning Out 2.0</h1>
<p class="page-desc">Embedded Salesforce LWC component rendered on this external (Heroku) page.</p>

<div class="lwc-container">
  <lightning-out-application
    id="mySalesforceApp"
    app-id="<%= appId %>"
    frontdoor-url="<%= frontdoorUrl %>"
    components="c-lightning-out-two-wrapper">
  </lightning-out-application>
  <c-lightning-out-two-wrapper header-title="Hello from <%= user.name %>!"></c-lightning-out-two-wrapper>
</div>

<script nonce="<%= cspNonce %>">
  const loApp = document.getElementById('mySalesforceApp');

  loApp.addEventListener('onready', () => {
    console.log('Lightning Out 2.0 is ready and rendered.');
    const lwcNode = document.querySelector('c-lightning-out-two-wrapper');

    if (lwcNode) {
      lwcNode.addEventListener('herokumessage', (event) => {
        console.log('Data received from Salesforce:', event.detail);
        const msgEl = document.createElement('p');
        msgEl.textContent = 'LWC says: ' + event.detail.message;
        document.querySelector('.lwc-container').appendChild(msgEl);
      });
      lwcNode.addEventListener('lo.component.ready', () => {
        console.log('The Salesforce LWC is now visible and interactive.');
      });
      console.log('Listeners successfully attached to LWC.');
    } else {
      console.error('LWC component could not be found even after onready.');
    }
  });
</script>

<%- include('partials/_foot') %>
