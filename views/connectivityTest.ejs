<%- include('partials/_head', { title: 'Connectivity Test — Clintox' }) %>

<h1 class="mb-3">Salesforce Connectivity Test</h1>

<div class="alert alert-warning mb-4" role="alert">
  <strong>Privacy notice:</strong> Credentials entered here and tokens acquired are used exclusively in-memory for a single request.
  They are never stored, logged, or persisted anywhere. They are destroyed the moment the request completes.
  <br/>
  <br/>
  <strong>Notes:</strong> This feature uses the OAuth 2.0 Web Server Flow. The Connected App in Salesforce should be configured with the <strong>No Secret Required</strong> option for the OAuth Web Server flow.
  The Connected App should also contain this callback url <strong>https://clintox.xyz/callbackbyoca</strong>
</div>

<% if (error) { %>
  <div class="alert alert-danger mb-3" role="alert"><%= error %></div>
<% } %>

<% if (!result) { %>
  <div id="formError" class="alert alert-danger mb-3 d-none" role="alert"></div>
  <form class="mb-4" id="testForm">
    <div class="mb-3">
      <label for="instanceUrl" class="form-label">Salesforce Instance URL</label>
      <input type="url" class="form-control" id="instanceUrl" name="instanceUrl"
        placeholder="https://myorg.my.salesforce.com" required>
    </div>
    <div class="mb-3">
      <label for="clientId" class="form-label">Client ID (Consumer Key)</label>
      <input type="text" class="form-control font-monospace" id="clientId" name="clientId"
        autocomplete="off" required>
    </div>
    <button type="submit" class="btn btn-primary" id="submitBtn">Run Test</button>
  </form>
  <script nonce="<%= cspNonce %>">
    document.getElementById('testForm').addEventListener('submit', function(e) {
      e.preventDefault();
      var btn = document.getElementById('submitBtn');
      var errorDiv = document.getElementById('formError');
      errorDiv.classList.add('d-none');
      btn.disabled = true;
      btn.textContent = 'Running…';

      var body = new URLSearchParams({
        instanceUrl: document.getElementById('instanceUrl').value,
        clientId: document.getElementById('clientId').value,
      });

      fetch('/connectivity-test/run', { method: 'POST', body: body })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.redirectUrl) {
            window.location.href = data.redirectUrl;
          } else {
            errorDiv.textContent = data.error || 'An unexpected error occurred.';
            errorDiv.classList.remove('d-none');
            btn.disabled = false;
            btn.textContent = 'Run Test';
          }
        })
        .catch(function() {
          errorDiv.textContent = 'Network error. Please try again.';
          errorDiv.style.display = '';
          btn.disabled = false;
          btn.textContent = 'Run Test';
        });
    });
  </script>
<% } %>

<% if (result) { %>
  <div class="card mb-4" id="resultsCard">
    <div class="card-body">
      <h5 class="card-title text-success mb-3">Connection successful</h5>
      <table class="endpoint-table">
        <tbody>
          <tr><td><strong>Instance URL</strong></td><td><%= result.instanceUrl %></td></tr>
          <tr><td><strong>Token acquired</strong></td><td><%= result.tokenAcquired %></td></tr>
          <tr><td><strong>User records visible</strong></td><td><%= result.recordCount %></td></tr>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
<%- include('partials/_foot') %>
