<%- include('partials/_head', { title: 'Connectivity Test — Clintox' }) %>

<h1 class="mb-3">Salesforce Connectivity Test</h1>

<div class="alert alert-warning mb-4" role="alert">
  <strong>Privacy notice:</strong> Credentials entered here are used exclusively in-memory for a single request.
  They are never stored, logged, or persisted anywhere. They are destroyed the moment the request completes.
  <br/>
  <br/>
  This feature uses the OAuth 2.0 Web Server Flow. Your connected app will need to contain the callback url <strong>https://clintox.xyz/callbackbyoca</strong>
</div>

<% if (error) { %>
  <div class="alert alert-danger mb-3" role="alert"><%= error %></div>
<% } %>

<% if (!result) { %>
  <form method="POST" action="/connectivity-test/run" class="mb-4" id="testForm">
    <div class="mb-3">
      <label for="instanceUrl" class="form-label">Salesforce Instance URL</label>
      <input type="url" class="form-control" id="instanceUrl" name="instanceUrl"
        placeholder="https://myorg.my.salesforce.com" required>
    </div>
    <div class="mb-3">
      <label for="clientId" class="form-label">Client ID (Consumer Key)</label>
      <input type="text" class="form-control font-monospace" id="clientId" name="clientId"
        autocomplete="off" required>
    </div>
    <div class="mb-3">
      <label for="clientSecret" class="form-label">Client Secret (Consumer Secret)</label>
      <input type="password" class="form-control font-monospace" id="clientSecret" name="clientSecret"
        autocomplete="off" required>
    </div>
    <button type="submit" class="btn btn-primary">Run Test</button>
  </form>
<% } %>

<% if (result) { %>
  <div class="card mb-4" id="resultsCard">
    <div class="card-body">
      <h5 class="card-title text-success mb-3">Connection successful</h5>
      <table class="endpoint-table">
        <tbody>
          <tr><td><strong>Instance URL</strong></td><td><%= result.instanceUrl %></td></tr>
          <tr><td><strong>Token acquired</strong></td><td><%= result.tokenAcquired %></td></tr>
          <tr><td><strong>User records visible</strong></td><td><%= result.recordCount %></td></tr>
        </tbody>
      </table>
    </div>
  </div>
<% } %>
<%- include('partials/_foot') %>
