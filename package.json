{
  "name": "simpleapi",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "saml-idp": "saml-idp --acsUrl http://localhost:3003/auth/sso/callback --audience http://localhost:3003",
    "gen:idp-cert": "mkdir -p certs && openssl req -x509 -newkey rsa:2048 -keyout certs/idp-key.pem -out certs/idp-cert.pem -days 730 -nodes -subj \"/CN=saml-idp\""
  },
  "jest": {
    "testEnvironment": "node"
  },
  "dependencies": {
    "@node-saml/passport-saml": "^5.1.0",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "connect-mongo": "^6.0.0",
    "connect-timeout": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.0",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "qs": "^6.11.2",
    "randomstring": "^1.3.0",
    "samlify": "^2.13.1"
  },
  "engines": {
    "node": "^24"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "saml-idp": "^1.2.1"
  }
}
