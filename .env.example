# App
NODE_ENV=development
PORT=3003
BASE_URL=http://localhost:3003

# Session — use a long random string in production
SESSION_SECRET=replace-with-a-strong-random-secret

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Salesforce OAuth (existing flows)
CLIENT_ID=
CLIENT_SECRET=

# ─── SAML IdP — this app acting as Identity Provider ─────────────────────────
# Entity ID for this IdP (defaults to BASE_URL/idp/metadata if blank)
IDP_ENTITY_ID=

# Private key for signing assertions — base64-encoded PEM (production/Heroku)
# In development, leave blank and use certs/idp-key.pem (run: npm run gen:idp-cert)
IDP_PRIVATE_KEY=

# X.509 signing certificate — base64-encoded PEM (production/Heroku)
# In development, leave blank and use certs/idp-cert.pem (run: npm run gen:idp-cert)
IDP_CERT=

# ─── Registered Service Provider (SP) ────────────────────────────────────────
# Entity ID of the SP that will trust this IdP
SP_ENTITY_ID=

# Assertion Consumer Service URL — where SAMLResponse is POSTed
SP_ACS_URL=

# Optional: SP's X.509 signing cert for AuthnRequest verification (base64 PEM body, no headers)
SP_CERT=

# ─── SAML SSO — Salesforce Identity Provider ─────────────────────────────────
# Find these values in Salesforce Setup > Identity > Single Sign-On Settings

# The Salesforce IdP SSO URL (HTTP Redirect binding)
# Example: https://your-org.my.salesforce.com/idp/endpoint/HttpRedirect
SAML_ENTRY_POINT=

# Service Provider Entity ID — uniquely identifies your app to Salesforce.
# Typically your app's base URL, e.g. https://clintox.xyz
SAML_ISSUER=

# The SAML callback URL Salesforce will POST the assertion to.
# Must match exactly what is registered in the Salesforce Connected App / SSO settings.
# Example: https://clintox.xyz/auth/sso/callback
SAML_CALLBACK_URL=

# Salesforce X.509 public certificate — paste the base64 body only (no -----BEGIN/END CERTIFICATE----- lines)
SAML_IDP_CERT=
